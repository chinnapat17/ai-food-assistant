    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-3.5-flash:generateContent?key=AQ.Ab8RN6KkfnBKz8URb6XM4dC7KhgeH7CKhxWhxuZ9jZxnoOkNow",
        "sendHeaders": true,
        "headerParameters": {
